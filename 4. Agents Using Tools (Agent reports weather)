import os
import requests
from google import genai
from google.genai import types


# -------- TOOLS --------

def get_weather(city: str) -> str:
    # Step 1: geocode city name to lat/lon
    geo = requests.get(
        "https://geocoding-api.open-meteo.com/v1/search",
        params={"name": city, "count": 1}
    ).json()
    
    if not geo.get("results"):
        return f"Could not find city: {city}"
    
    lat = geo["results"][0]["latitude"]
    lon = geo["results"][0]["longitude"]
    
    # Step 2: get current temperature
    weather = requests.get(
        "https://api.open-meteo.com/v1/forecast",
        params={
            "latitude": lat,
            "longitude": lon,
            "current_weather": True
        }
    ).json()
    
    temp = weather["current_weather"]["temperature"]
    return f"Weather in {city} is {temp}°C"
def add_numbers(a, b):
    return a + b


# -------- TOOL DECLARATION --------

tools = [
    types.Tool(
        function_declarations=[
            types.FunctionDeclaration(
                name="get_weather",
                description="Get weather",
                parameters={
                    "type": "OBJECT",
                    "properties": {"city": {"type": "STRING"}},
                    "required": ["city"]
                }
            ),
            types.FunctionDeclaration(
                name="add_numbers",
                description="Add numbers",
                parameters={
                    "type": "OBJECT",
                    "properties": {
                        "a": {"type": "NUMBER"},
                        "b": {"type": "NUMBER"}
                    },
                    "required": ["a", "b"]
                }
            )
        ]
    )
]


# -------- HELPER --------

def get_text(resp):
    if resp.text:
        return resp.text

    parts = resp.candidates[0].content.parts
    return " ".join([p.text for p in parts if p.text]) or "No response"


def get_function_call(resp):
    parts = resp.candidates[0].content.parts
    for p in parts:
        if p.function_call:
            return p.function_call
    return None


# -------- AGENT --------

class Agent:
    def __init__(self, name, prompt):
        self.name = name
        self.prompt = prompt
        self.client = genai.Client(api_key=os.environ.get("GEMINI_API_KEY"))
        self.model = "gemini-flash-latest"

    def think(self, text):
        if not text:
            text = "continue"

        config = types.GenerateContentConfig(
            system_instruction=[types.Part.from_text(text=self.prompt)],
            tools=tools
        )

        user_msg = types.Content(
            role="user",
            parts=[types.Part.from_text(text=text)]
        )

        resp = self.client.models.generate_content(
            model=self.model,
            contents=[user_msg],
            config=config
        )

        fc = get_function_call(resp)

        # -------- TOOL CALL --------
        if fc:
            name, args = fc.name, fc.args
            print(f"\n⚙️ {self.name} -> {name} {args}")

            if name == "get_weather":
                result = get_weather(**args)
            elif name == "add_numbers":
                result = add_numbers(**args)
            else:
                result = "Unknown tool"

            print(f"🔧 {result}")

            tool_msg = types.Content(
                role="tool",
                parts=[
                    types.Part.from_function_response(
                        name=name,
                        response={"result": result}
                    )
                ]
            )

            final = self.client.models.generate_content(
                model=self.model,
                contents=[
                    user_msg,
                    types.Content(role="model", parts=resp.candidates[0].content.parts),
                    tool_msg
                ],
                config=config
            )

            out = get_text(final)

        else:
            out = get_text(resp)

        print(out)
        return out


# -------- RUN --------

if __name__ == "__main__":
    human = Agent("Shashank", "You are a human")
    dog = Agent("Bruno", "You are a smart dog")

    msg = "What's the weather in Chennai?"

    for _ in range(1):
        print(f"\nShashank:", end=" ")
        msg = human.think(msg)

        print(f"\nBruno:", end=" ")
        msg = dog.think(msg)
